  ---
import Vimeo from './vimeo.astro';
import Details from './details.astro';
import Tiles from '../components/tiles.astro';
import type { Project } from '../types/project';

interface Props {
  project: Project;
  projects: Project[];
  featuredProjects: Project[];
  currentIndex: number;  
}

const { project, projects, featuredProjects, currentIndex } = Astro.props as Props;
---
  
<div class="title">
  <a href="#" title="left" class="js-index"
        data-step="-1">
        <img class="left" src="/icon/arrow_icon.svg" alt="left" /></a>

  <div>
    <div class="line1"><h1 id="featured-title">{project.title}</h1>
    <a href="#" title="right" class="js-index"
        data-step="1">
        <img class="right" src="/icon/arrow_icon.svg" alt="right" /></a>
    </div>
    <h2 id="featured-subtitle">{project.subtitle}</h2>
  </div>
</div>

<div class="grid">

  <div class="main">

    <div class="featured-vimeo">
      {featuredProjects.map((item, index) => (
        <div class={`slide ${index === currentIndex ? 'is-active' : ''}`}>
          <Vimeo project={item} />
        </div>
      ))}
    </div>
  </div>

  <div class="featured-details">
  {featuredProjects.map((item, index) => (
    <div class={`details-slide ${index === currentIndex ? 'is-active' : ''}`}>
      <Details 
        project={item} 
        detailsId={`details-${item.slug}`} 
      />
    </div>
  ))}
</div>

  <Tiles projects={projects} />

</div>
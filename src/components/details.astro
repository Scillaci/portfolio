---
import type { Project } from '../types/project';

const { project, detailsId } = Astro.props as {
  project: Project;
  detailsId?: string;
};

const id = detailsId ?? `details-${project.slug}`;

const rows = [
  { label: "client", value: project.client },
  { label: "role", value: project.role?.join(" | ") },
  ...(project.collaborators ?? []).map((item) => ({
    label: item.title,
    value: item.name
  })),
  { label: "year", value: project.year }
].filter((row) => row.value);
